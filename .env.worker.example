# Copy this file to `.env.worker` and fill in local values.
# This file is safe to commit; `.env.worker` stays ignored.

APP_BASE_URL=https://operations.getaxiom.ca
AGENT_SHARED_SECRET=<AGENT_SHARED_SECRET>
WORKER_NAME=local-worker
GEMINI_API_KEY=<GEMINI_API_KEY>
SCRAPE_TIMEOUT_MS=600000
CLAIM_POLL_INTERVAL_MS=5000
HEARTBEAT_INTERVAL_MS=15000
